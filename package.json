{
  "name": "wave2vector-spotify-live",
  "version": "1.0.0",
  "description": "Spotify live recommendation starter for Wave2Vector",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "check": "tsc --noEmit -p tsconfig.json",
    "smoke": "node scripts/smoke.mjs",
    "test:easy": "npm run check && npm run build && npm run smoke"
  },
  "keywords": [
    "spotify",
    "recommendations",
    "wave2vector"
  ],
  "author": "",
  "license": "ISC",
  "type": "module",
  "dependencies": {
    "@upstash/redis": "^1.34.2",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "livekit-server-sdk": "^2.14.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  }
}
